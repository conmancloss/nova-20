{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nova-20",
  "main": "orker.js",
  "compatibility_date": "2026-04-10",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "static",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
